  membership         VendorMembership @relation(fields: [vendorId, membershipId], references: [vendorId, id])
  user               User             @relation(fields: [userId], references: [id])
  identity           UserIdentity     @relation(fields: [identityId, userId], references: [id, userId])

  @@index([vendorId, expiresAt])
  @@map("owner_enrollments")
}

model PlatformRoleAssignment {
  id        String       @id @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      PlatformRole
  grantedBy String       @map("granted_by") @db.Uuid
  grantedAt DateTime     @default(now()) @map("granted_at") @db.Timestamptz(6)
  revokedAt DateTime?    @map("revoked_at") @db.Timestamptz(6)
  user      User         @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@map("platform_role_assignments")
}

model SupportAccessGrant {
  id            String    @id @db.Uuid
  vendorId      String    @map("vendor_id") @db.Uuid
  granteeUserId String    @map("grantee_user_id") @db.Uuid
  requestedBy   String    @map("requested_by") @db.Uuid
  approvedBy    String    @map("approved_by") @db.Uuid
  purpose       String
  scope         Json      @map("scope_json")
  accessMode    String    @default("read") @map("access_mode")
  startsAt      DateTime  @map("starts_at") @db.Timestamptz(6)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  vendor        Vendor    @relation(fields: [vendorId], references: [id])

  @@index([vendorId, granteeUserId, expiresAt])
  @@map("support_access_grants")
}

model AuditEvent {
  id            String   @id @db.Uuid
  vendorId      String?  @map("vendor_id") @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  action        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id") @db.Uuid
  oldValue      Json?    @map("old_value")
  newValue      Json?    @map("new_value")
  reason        String?
  correlationId String   @map("correlation_id") @db.Uuid
  ipHash        String?  @map("ip_hash")
  deviceId      String?  @map("device_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  vendor        Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([vendorId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("audit_events")
}
