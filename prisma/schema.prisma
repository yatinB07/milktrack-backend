generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  deactivated
}

enum IdentityType {
  phone
  email
}

enum MfaFactorType {
  totp
}

enum VendorStatus {
  pending_approval
  onboarding
  trial
  active
  suspended
  closed
}

enum MembershipRole {
  vendor_owner
  vendor_administrator
  delivery_agent
  customer
}

enum MembershipStatus {
  invited
  active
  ended
}

enum HouseholdStatus {
  active
  inactive
}

enum HouseholdMemberStatus {
  active
  ended
}

enum CatalogStatus {
  active
  inactive
}

enum PlatformRole {
  product_owner
  platform_administrator
  support_operations
}

enum OtpPurpose {
  sign_in
}

enum AuthenticationMethod {
  phone_otp
  administrator_mfa
}

model User {
  id               String                     @id @db.Uuid
  displayName      String                     @map("display_name")
  status           UserStatus                 @default(active)
  locale           String                     @default("en")
  deactivatedAt    DateTime?                  @map("deactivated_at") @db.Timestamptz(6)
  deletedAt        DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  deletedBy        String?                    @map("deleted_by") @db.Uuid
  deletionReason   String?                    @map("deletion_reason")
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  identities       UserIdentity[]
  password         PasswordCredential?
  mfaFactors       MfaFactor[]
  pendingMfa       PendingMfaAuthentication[]
  sessions         Session[]
  memberships      VendorMembership[]
  platformRoles    PlatformRoleAssignment[]
  ownerEnrollments OwnerEnrollment[]
  globalPricesCreated GlobalPrice[]             @relation("GlobalPriceCreator")
  priceOverridesCreated CustomerPriceOverride[] @relation("CustomerPriceOverrideCreator")
  subscriptionRevisionsCreated SubscriptionRevision[] @relation("SubscriptionRevisionCreator")
  subscriptionsDeleted Subscription[] @relation("SubscriptionDeleter")
  routesDeleted Route[] @relation("RouteDeleter")
  routeStopPlansCreated RouteStopPlan[] @relation("RouteStopPlanCreator")
  routeStopsCreated RouteStop[] @relation("RouteStopCreator")
  routeAssignmentsCreated RouteAssignment[] @relation("RouteAssignmentCreator")
  routeAssignmentsUpdated RouteAssignment[] @relation("RouteAssignmentUpdater")
  scheduleGenerationRunsRequested ScheduleGenerationRun[] @relation("ScheduleGenerationRunRequester")
  leaveRequestRevisionsCreated LeaveRequestRevision[] @relation("LeaveRequestRevisionCreator")
  leaveRequestRevisionsDecided LeaveRequestRevision[] @relation("LeaveRequestRevisionDecider")
  leaveOccurrenceDecisionsDecided LeaveOccurrenceDecision[] @relation("LeaveOccurrenceDecisionDecider")
  deliveryEventsActed DeliveryEvent[] @relation("DeliveryEventActor")
  notificationsReceived Notification[] @relation("NotificationRecipient")

  @@map("users")
}

model UserIdentity {
  id               String            @id @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  type             IdentityType
  normalizedValue  String            @map("normalized_value")
  verifiedAt       DateTime?         @map("verified_at") @db.Timestamptz(6)
  isPrimary        Boolean           @default(false) @map("is_primary")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User              @relation(fields: [userId], references: [id])
  challenges       OtpChallenge[]
  ownerEnrollments OwnerEnrollment[]

  @@unique([id, userId])
  @@unique([type, normalizedValue])
  @@map("user_identities")
}

model PasswordCredential {
  userId         String    @id @map("user_id") @db.Uuid
  passwordHash   String    @map("password_hash")
  salt           String
  algorithm      String
  parameters     Json
  changedAt      DateTime  @map("changed_at") @db.Timestamptz(6)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id])

  @@map("password_credentials")
}

model MfaFactor {
  id              String        @id @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  type            MfaFactorType
  encryptedSecret String        @map("encrypted_secret")
  enabledAt       DateTime      @map("enabled_at") @db.Timestamptz(6)
  lastUsedAt      DateTime?     @map("last_used_at") @db.Timestamptz(6)
  lastUsedCounter BigInt?       @map("last_used_counter") @db.BigInt
  revokedAt       DateTime?     @map("revoked_at") @db.Timestamptz(6)
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@map("mfa_factors")
}

model PendingMfaAuthentication {
  id                          String    @id @db.Uuid
  userId                      String    @map("user_id") @db.Uuid
  tokenHash                   String    @unique @map("token_hash")
  deviceId                    String    @map("device_id")
  passwordCredentialChangedAt DateTime  @map("password_credential_changed_at") @db.Timestamptz(6)
  expiresAt                   DateTime  @map("expires_at") @db.Timestamptz(6)
  attemptCount                Int       @default(0) @map("attempt_count")
  consumedAt                  DateTime? @map("consumed_at") @db.Timestamptz(6)
  requestIpHash               String?   @map("request_ip_hash")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user                        User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([requestIpHash, createdAt(sort: Desc)])
  @@map("pending_mfa_authentications")
}

model AdministratorAuthenticationAttempt {
  id         String   @id @db.Uuid
  accountKey String   @map("account_key")
  ipHash     String?  @map("ip_hash")
  stage      String
  succeeded  Boolean
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountKey, stage, createdAt(sort: Desc)], map: "administrator_auth_attempts_account_stage_created_idx")
  @@index([ipHash, stage, createdAt(sort: Desc)], map: "administrator_auth_attempts_ip_stage_created_idx")
  @@map("administrator_authentication_attempts")
}

model OtpChallenge {
  id              String        @id @db.Uuid
  identityId      String?       @map("identity_id") @db.Uuid
  tokenHash       String        @unique @map("token_hash")
  destinationHash String        @map("destination_hash")
  purpose         OtpPurpose
  codeHash        String        @map("code_hash")
  expiresAt       DateTime      @map("expires_at") @db.Timestamptz(6)
  attemptCount    Int           @default(0) @map("attempt_count")
  consumedAt      DateTime?     @map("consumed_at") @db.Timestamptz(6)
  requestIpHash   String?       @map("request_ip_hash")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  identity        UserIdentity? @relation(fields: [identityId], references: [id])

  @@index([destinationHash, purpose, createdAt(sort: Desc)])
  @@map("otp_challenges")
}

model Session {
  id                   String               @id @db.Uuid
  userId               String               @map("user_id") @db.Uuid
  accessTokenHash      String               @unique @map("access_token_hash")
  refreshTokenHash     String               @unique @map("refresh_token_hash")
  predecessorId        String?              @unique @map("predecessor_id") @db.Uuid
  authenticationMethod AuthenticationMethod @map("authentication_method")
  deviceId             String               @map("device_id")
  deviceName           String?              @map("device_name")
  ipHash               String?              @map("ip_hash")
  userAgent            String?              @map("user_agent")
  accessExpiresAt      DateTime             @map("access_expires_at") @db.Timestamptz(6)
  expiresAt            DateTime             @map("expires_at") @db.Timestamptz(6)
  revokedAt            DateTime?            @map("revoked_at") @db.Timestamptz(6)
  lastSeenAt           DateTime             @map("last_seen_at") @db.Timestamptz(6)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  user                 User                 @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt])
  @@map("sessions")
}

model Vendor {
  id                String               @id @db.Uuid
  code              String
  legalName         String               @map("legal_name")
  displayName       String               @map("display_name")
  status            VendorStatus         @default(pending_approval)
  timezone          String
  currency          String               @db.Char(3)
  skipCutoffMinutes Int                  @map("skip_cutoff_minutes")
  lateLeavePolicy   String               @default("approval") @map("late_leave_policy")
  captureAgentLocationEvidence Boolean  @default(false) @map("capture_agent_location_evidence")
  billingDay        Int                  @map("billing_day")
  version           Int                  @default(1)
  deletedAt         DateTime?            @map("deleted_at") @db.Timestamptz(6)
  deletedBy         String?              @map("deleted_by") @db.Uuid
  deletionReason    String?              @map("deletion_reason")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships       VendorMembership[]
  supportGrants     SupportAccessGrant[]
  auditEvents       AuditEvent[]
  ownerEnrollments  OwnerEnrollment[]
  households        Household[]
  units             Unit[]
  products          Product[]
  deliverySlots     DeliverySlot[]
  globalPrices      GlobalPrice[]
  priceOverrides    CustomerPriceOverride[]
  subscriptions     Subscription[]
  routes Route[]
  routeStopPlans RouteStopPlan[]
  routeAssignments RouteAssignment[]
  scheduledDeliveries ScheduledDelivery[]
  scheduleGenerationRuns ScheduleGenerationRun[]
  leaveRequests LeaveRequest[]
  leaveRequestRevisions LeaveRequestRevision[]
  leaveRevisionSubscriptions LeaveRevisionSubscription[]
  leaveOccurrenceDecisions LeaveOccurrenceDecision[]
  deliveryEvents DeliveryEvent[]
  deliveryPriceSnapshots DeliveryPriceSnapshot[]
  notifications Notification[]

  @@map("vendors")
}

model VendorMembership {
  id              String           @id @db.Uuid
  vendorId        String           @map("vendor_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  role            MembershipRole
  status          MembershipStatus @default(invited)
  joinedAt        DateTime?        @map("joined_at") @db.Timestamptz(6)
  endedAt         DateTime?        @map("ended_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  deletedBy       String?          @map("deleted_by") @db.Uuid
  deletionReason  String?          @map("deletion_reason")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor          Vendor           @relation(fields: [vendorId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  ownerEnrollments OwnerEnrollment[]
  householdMembers HouseholdMember[]
  routeAssignments RouteAssignment[]

  @@unique([vendorId, id])
  @@index([vendorId, status, id])
  @@map("vendor_memberships")
}

model Household {
  id             String          @id @db.Uuid
  vendorId       String          @map("vendor_id") @db.Uuid
  accountNumber  String          @map("account_number")
  name           String
  addressLine1   String          @map("address_line_1")
  addressLine2   String?         @map("address_line_2")
  locality       String?
  city           String
  region         String
  postalCode     String          @map("postal_code")
  countryCode    String          @map("country_code") @db.Char(2)
  latitude       Decimal?        @db.Decimal(9, 6)
  longitude      Decimal?        @db.Decimal(10, 6)
  status         HouseholdStatus @default(active)
  notes          String?
  version        Int             @default(1)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?         @map("deleted_by") @db.Uuid
  deletionReason String?         @map("deletion_reason")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members        HouseholdMember[]
  priceOverrides CustomerPriceOverride[]
  subscriptions Subscription[]
  routeStops RouteStop[]
  scheduledDeliveries ScheduledDelivery[]
  leaveRequests LeaveRequest[]

  @@unique([vendorId, id])
  @@index([vendorId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("households")
}

model HouseholdMember {
  id                   String                @id @db.Uuid
  vendorId             String                @map("vendor_id") @db.Uuid
  householdId          String                @map("household_id") @db.Uuid
  customerMembershipId String                @map("customer_membership_id") @db.Uuid
  status               HouseholdMemberStatus @default(active)
  joinedAt             DateTime              @map("joined_at") @db.Timestamptz(6)
  endedAt              DateTime?             @map("ended_at") @db.Timestamptz(6)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  household            Household             @relation(fields: [vendorId, householdId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "household_members_household_fkey")
  customerMembership   VendorMembership      @relation(fields: [vendorId, customerMembershipId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "household_members_customer_membership_fkey")

  @@unique([vendorId, id])
  @@index([vendorId, householdId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("household_members")
}

model Unit {
  id           String        @id @db.Uuid
  vendorId     String        @map("vendor_id") @db.Uuid
  code         String
  name         String
  decimalScale Int           @map("decimal_scale")
  status       CatalogStatus @default(active)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor       Vendor        @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products     Product[]

  @@unique([vendorId, id])
  @@unique([vendorId, code])
  @@index([vendorId, status, createdAt(sort: Desc), id(sort: Desc)])
  @@map("units")
}

model Product {
  id             String        @id @db.Uuid
  vendorId       String        @map("vendor_id") @db.Uuid
  code           String
  name           String
  defaultUnitId  String        @map("default_unit_id") @db.Uuid
  status         CatalogStatus @default(active)
  version        Int           @default(1)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?       @map("deleted_by") @db.Uuid
  deletionReason String?       @map("deletion_reason")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor         Vendor        @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  defaultUnit    Unit          @relation(fields: [vendorId, defaultUnitId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "products_default_unit_fkey")
  globalPrices   GlobalPrice[] @relation("GlobalPriceProduct")
  priceOverrides CustomerPriceOverride[] @relation("CustomerPriceOverrideProduct")
  subscriptionRevisions SubscriptionRevision[]
  scheduledDeliveries ScheduledDelivery[]

  @@unique([vendorId, id])
  @@unique([vendorId, id, defaultUnitId])
  @@map("products")
}

model DeliverySlot {
  id             String   @id @db.Uuid
  vendorId       String   @map("vendor_id") @db.Uuid
  code           String
  name           String
  startLocalTime DateTime @map("start_local_time") @db.Time(0)
  endLocalTime   DateTime @map("end_local_time") @db.Time(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor         Vendor   @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptionRevisions SubscriptionRevision[]
  routes Route[]
  scheduledDeliveries ScheduledDelivery[]
  leaveOccurrenceDecisions LeaveOccurrenceDecision[]

  @@unique([vendorId, id])
  @@unique([vendorId, code])
  @@index([vendorId, active, createdAt(sort: Desc), id(sort: Desc)])
  @@map("delivery_slots")
}

model GlobalPrice {
  id            String   @id @db.Uuid
  vendorId      String   @map("vendor_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  unitId        String   @map("unit_id") @db.Uuid
  amountMinor   BigInt   @map("amount_minor") @db.BigInt
  currency      String   @db.Char(3)
  effectiveFrom DateTime @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product       Product  @relation("GlobalPriceProduct", fields: [vendorId, productId, unitId], references: [vendorId, id, defaultUnitId], onDelete: NoAction, onUpdate: NoAction, map: "global_prices_product_unit_fkey")
  creator       User     @relation("GlobalPriceCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vendorId, id])
  @@index([vendorId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([vendorId, productId, unitId, effectiveFrom(sort: Desc), effectiveTo], map: "global_prices_resolution_idx")
  @@map("global_prices")
}

model CustomerPriceOverride {
  id            String   @id @db.Uuid
  vendorId      String   @map("vendor_id") @db.Uuid
  householdId   String   @map("household_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  unitId        String   @map("unit_id") @db.Uuid
  amountMinor   BigInt   @map("amount_minor") @db.BigInt
  currency      String   @db.Char(3)
  effectiveFrom DateTime @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)
  reason        String
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  household     Household @relation(fields: [vendorId, householdId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "customer_price_overrides_household_fkey")
  product       Product  @relation("CustomerPriceOverrideProduct", fields: [vendorId, productId, unitId], references: [vendorId, id, defaultUnitId], onDelete: NoAction, onUpdate: NoAction, map: "customer_price_overrides_product_unit_fkey")
  creator       User     @relation("CustomerPriceOverrideCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vendorId, id])
  @@index([vendorId, householdId, createdAt(sort: Desc), id(sort: Desc)], map: "customer_price_overrides_vendor_id_household_id_created_at_id_i")
  @@index([vendorId, householdId, productId, unitId, effectiveFrom(sort: Desc), effectiveTo], map: "customer_price_overrides_resolution_idx")
  @@map("customer_price_overrides")
}

model Subscription {
  id             String    @id @db.Uuid
  vendorId       String    @map("vendor_id") @db.Uuid
  householdId    String    @map("household_id") @db.Uuid
  version        Int       @default(1)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy      String?   @map("deleted_by") @db.Uuid
  deletionReason String?   @map("deletion_reason")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  vendor         Vendor    @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  household      Household @relation(fields: [vendorId, householdId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "subscriptions_household_fkey")
  deleter        User?     @relation("SubscriptionDeleter", fields: [deletedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revisions      SubscriptionRevision[]
  scheduledDeliveries ScheduledDelivery[]
  leaveRevisionSubscriptions LeaveRevisionSubscription[]

  @@unique([vendorId, id])
  @@unique([vendorId, id, householdId])
  @@index([vendorId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([vendorId, householdId, createdAt(sort: Desc), id(sort: Desc)])
  @@map("subscriptions")
}

model SubscriptionRevision {
  id                     String    @id @db.Uuid
  vendorId               String    @map("vendor_id") @db.Uuid
  subscriptionId         String    @map("subscription_id") @db.Uuid
  productId              String    @map("product_id") @db.Uuid
  unitId                 String    @map("unit_id") @db.Uuid
  deliverySlotId         String    @map("delivery_slot_id") @db.Uuid
  quantity               Decimal   @db.Decimal(18, 3)
  status                 String
  effectiveFrom          DateTime  @map("effective_from") @db.Date
  effectiveTo            DateTime? @map("effective_to") @db.Date
  createdBy              String    @map("created_by") @db.Uuid
  supersededAt           DateTime? @map("superseded_at") @db.Timestamptz(6)
  supersededByRevisionId String?   @map("superseded_by_revision_id") @db.Uuid
  supersessionReason     String?   @map("supersession_reason")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscription           Subscription @relation(fields: [vendorId, subscriptionId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "subscription_revisions_subscription_fkey")
  product                Product   @relation(fields: [vendorId, productId, unitId], references: [vendorId, id, defaultUnitId], onDelete: NoAction, onUpdate: NoAction, map: "subscription_revisions_product_unit_fkey")
  deliverySlot           DeliverySlot @relation(fields: [vendorId, deliverySlotId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "subscription_revisions_delivery_slot_fkey")
  creator                User      @relation("SubscriptionRevisionCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supersededBy           SubscriptionRevision? @relation("RevisionSupersession", fields: [vendorId, subscriptionId, supersededByRevisionId], references: [vendorId, subscriptionId, id], onDelete: NoAction, onUpdate: NoAction, map: "subscription_revisions_supersession_fkey")
  supersededRevisions    SubscriptionRevision[] @relation("RevisionSupersession")
  weekdays               SubscriptionRevisionWeekday[]
  scheduledDeliveries    ScheduledDelivery[]

  @@unique([vendorId, id])
  @@unique([vendorId, subscriptionId, id])
  @@unique([vendorId, subscriptionId, id, productId, unitId, deliverySlotId], map: "subscription_revisions_schedule_projection_key")
  @@index([vendorId, subscriptionId, effectiveFrom, id], map: "subscription_revisions_current_plan_idx")
  @@index([vendorId, subscriptionId, createdAt(sort: Desc), id(sort: Desc)], map: "subscription_revisions_history_idx")
  @@map("subscription_revisions")
}

model SubscriptionRevisionWeekday {
  vendorId               String @map("vendor_id") @db.Uuid
  subscriptionRevisionId String @map("subscription_revision_id") @db.Uuid
  weekday                Int    @db.SmallInt
  revision               SubscriptionRevision @relation(fields: [vendorId, subscriptionRevisionId], references: [vendorId, id], onDelete: NoAction, onUpdate: NoAction, map: "subscription_revision_weekdays_revision_fkey")

  @@id([vendorId, subscriptionRevisionId, weekday])
  @@map("subscription_revision_weekdays")
}

model Route {
  id             String        @id @db.Uuid
  vendorId       String        @map("vendor_id") @db.Uuid
  code           String
  name           String
  deliverySlotId String        @map("delivery_slot_id") @db.Uuid
  status         CatalogStatus @default(active)
