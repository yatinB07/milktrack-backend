# Safe local-only values; copy this file to .env and do not reuse them elsewhere.
POSTGRES_DB=milktrack
POSTGRES_USER=milktrack_owner
POSTGRES_PASSWORD=milktrack_owner_local
MILKTRACK_APP_PASSWORD=milktrack_app_local
MIGRATION_DATABASE_URL=postgresql://milktrack_owner:milktrack_owner_local@postgres:5432/milktrack
DATABASE_URL=postgresql://milktrack_app:milktrack_app_local@postgres:5432/milktrack
BACKEND_PORT=3000
AUTH_HMAC_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
MFA_ENCRYPTION_KEY=ZmVkY2JhOTg3NjU0MzIxMGZlZGNiYTk4NzY1NDMyMTA=
SESSION_TTL_SECONDS=2592000
APP_ENV=development
OTP_PROVIDER=local

# Required only for explicit development/test seeding; provide values at invocation time.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_TOTP_SECRET=

# PostgreSQL init scripts run only when postgres_data is first created.
# `docker compose down` preserves local data; `docker compose down -v` destroys it.
