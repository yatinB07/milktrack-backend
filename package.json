{
  "name": "milktrack-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "nest build",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:validate": "prisma validate",
    "lint": "eslint .",
    "openapi:check": "npm run build --silent && tsx scripts/export-openapi.ts --check",
    "openapi:generate": "npm run build --silent && tsx scripts/export-openapi.ts",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "node --import tsx --test test/health.e2e.test.ts test/validation.e2e.test.ts $(find test -name '*.test.ts' ! -name '*.integration.test.ts' ! -name '*.e2e.test.ts' -print)",
    "test:integration": "node --import tsx --test $(find test -type f \\( -name '*.integration.test.ts' -o -name '*.e2e.test.ts' \\) ! -name 'security-release.integration.test.ts' -print)",
    "test:security": "node -e \"for (const name of ['SECURITY_SENTINEL_USER_ID','SECURITY_SENTINEL_VENDOR_ID','SECURITY_SENTINEL_MEMBERSHIP_ID','SECURITY_SENTINEL_AUDIT_ID','SECURITY_SENTINEL_SESSION_ID']) if (!process.env[name]) throw new Error('Missing required security sentinel environment variable: ' + name)\" && node --import tsx --test --test-concurrency=1 test/security-release.integration.test.ts test/security-schema.integration.test.ts test/tenant-transaction.integration.test.ts test/authorization-policy.integration.test.ts test/authentication.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "helmet": "8.3.0",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.24",
    "@types/cookie-parser": "1.4.10",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "eslint": "10.7.0",
    "prisma": "7.8.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
